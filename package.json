{
  "name": "bettermao-im",
  "version": "1.0.0",
  "description": "BetterMao IM Project - A real-time instant messaging application",
  "main": "app.js",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "lint": "eslint .",
    "build": "npm run build-frontend && npm run build-backend",
    "build-frontend": "cd ./ui && npm install && npm run build",
    "build-backend": "mkdir dist 2>nul || mkdir dist && xcopy uploads dist/uploads /E /I /Y 2>nul || echo No uploads directory to copy",
    "start:prod": "set NODE_ENV=production && node app.js",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "clean": "rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean && npm install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/bettermao-im.git"
  },
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "config-lite": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.0",
    "nedb-promises": "^6.2.1",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.5.0",
    "commitlint": "^19.5.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.6",
    "nodemon": "^3.1.9",
    "prettier": "^3.3.3"
  },
  "resolutions": {
    "rimraf": "^5.0.5",
    "glob": "^10.4.5",
    "inflight": "^1.0.6",
    "npmlog": "^7.0.1",
    "gauge": "^5.0.1",
    "are-we-there-yet": "^4.0.1",
    "@npmcli/move-file": "^3.0.0"
  }
}
