{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/app.js"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "src/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/$1",
      "status": 200
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "SUPABASE_URL": "${SUPABASE_URL}",
    "SUPABASE_KEY": "${SUPABASE_KEY}",
    "JWT_SECRET": "${JWT_SECRET}",
    "DATABASE_URL": "postgresql://postgres:cyccodemao1234@db.gnvfhfzhlyqradzqsysl.supabase.co:5432/postgres?sslmode=require",
    "REDIS_URL": "rediss://default:gQAAAAAAAQ7JAAIncDFjZTc0YTc3YmRiYzk0OGJlOWVlOTM0MTExZDAxNTEwNXAxNjkzMjE@immune-bengal-69321.upstash.io:6379",
    "FRONTEND_URL": "${FRONTEND_URL}",
    "PORT": "3000"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    },
    "commands": [
      "npm install",
      "cd frontend && npm install",
      "cd frontend && npm run build",
      "npx prisma generate"
    ]
  }
}