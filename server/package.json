{
  "name": "bettermao-server",
  "version": "1.0.0",
  "description": "Backend for BetterMao IM",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "npx prisma migrate dev",
    "build": "npm run build-frontend && npm run build-backend",
    "build-frontend": "cd ./frontend && npm install && npm run build",
    "build-backend": "npx prisma generate && mkdir dist 2>nul || mkdir dist && xcopy uploads dist/uploads /E /I /Y 2>nul || echo No uploads directory to copy",
    "start:prod": "set NODE_ENV=production && node src/app.js"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.5",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "minimatch": "^10.2.4",
    "morgan": "^1.10.0",
    "multer": "^2.1.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.4.0"
  }
}
