# Server Configuration
PORT=3000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key

# Database Configuration
# For development and production: PostgreSQL with SSL
DATABASE_URL=postgresql://user:password@localhost:5432/bettermao?sslmode=require

# Redis Configuration
# For development: in-memory mock (auto-detected)
# For production: Redis server URL
REDIS_URL=redis://localhost:6379

# Frontend Configuration
FRONTEND_URL=http://localhost:5173